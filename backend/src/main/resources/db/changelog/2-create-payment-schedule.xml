<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="2025-01-02-create-payment-schedule" author="loanapp">
        <createTable tableName="payment_schedule">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="loan_application_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_schedule_loan" references="loan_application(id)"/>
            </column>
            <column name="payment_number" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="payment_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="principal_amount" type="NUMERIC(15,2)">
                <constraints nullable="false"/>
            </column>
            <column name="interest_amount" type="NUMERIC(15,2)">
                <constraints nullable="false"/>
            </column>
            <column name="total_payment" type="NUMERIC(15,2)">
                <constraints nullable="false"/>
            </column>
            <column name="remaining_balance" type="NUMERIC(15,2)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="payment_schedule" indexName="idx_schedule_loan_id">
            <column name="loan_application_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>